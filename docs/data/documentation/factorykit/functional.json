{"hierarchy":{"paths":[["doc:\/\/FactoryKit\/documentation\/FactoryKit"]]},"abstract":[{"type":"text","text":"Factory can inject more than service classes and structs."}],"identifier":{"url":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Functional","interfaceLanguage":"swift"},"seeAlsoSections":[{"anchor":"Advanced-Topics","identifiers":["doc:\/\/FactoryKit\/documentation\/FactoryKit\/Design","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Modifiers","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Modules","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Cycle","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Optionals","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Tags"],"generated":true,"title":"Advanced Topics"}],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Functional Injection is a powerful tool that can, in many cases, eliminate the need for defining protocols, implementations, and the various stubs and mocks one needs when doing traditional Protocol-Oriented-Programing."}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"text":"Consider the following typealias and Factory.","type":"text"}]},{"code":["typealias AccountProviding = () async throws -> [Account]","","extension Container {","    var accountProvider: Factory<AccountProviding> {","        self {{ try await Network.get(path: \"\/accounts\") }}","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note the double braces. In this example our factory closure is returning a closure, not a class or struct."}]},{"type":"paragraph","inlineContent":[{"text":"Now, here’s the view model that uses it.","type":"text"}]},{"code":["class AccountViewModel: ObservableObject {","    @Injected(\\.accountProvider) var accountProvider","    @Published var accounts: [Account] = []","    @MainActor func load() async {","        do {","            accounts = try await accountProvider()","        } catch {","            print(error)","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Testing","type":"heading","text":"Testing","level":2},{"type":"paragraph","inlineContent":[{"text":"Now consider how easy it is to write a test with mock accounts…","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["func testAllAccounts() async {","    Container.shared.accountProvider.register {{ Account.mockAccounts }}","    do {","        let viewModel = AccountViewModel()","        try await viewModel.load()","        XCTAssert(viewModel.accounts.count == 5)","    } catch {","        XCTFail(\"Account load failed\")","    }","}"]},{"inlineContent":[{"type":"text","text":"Or test edge cases like no accounts found."}],"type":"paragraph"},{"code":["func testEmptyAccounts() async {","    Container.shared.accountProvider.register {{ [] }}","    ...","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Or test specific error cases.","type":"text"}]},{"code":["func testErrorLoadingAccounts() async {","    Container.shared.accountProvider.register {{ throw APIError.network }}","    ...","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here’s an article that goes into the technique in more detail: "},{"identifier":"https:\/\/betterprogramming.pub\/factory-and-functional-dependency-injection-2d0a38042d05","type":"reference","isActive":true}]}],"kind":"content"}],"sections":[],"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"article","modules":[{"name":"FactoryKit"}],"roleHeading":"Article","title":"Functional Injection"},"variants":[{"paths":["\/documentation\/factorykit\/functional"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://FactoryKit/documentation/FactoryKit/Modifiers":{"kind":"article","title":"Factory Modifiers","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Modifiers","type":"topic","url":"\/documentation\/factorykit\/modifiers","abstract":[{"type":"text","text":"Considerations when defining and redefining a Factory’s behavior."}],"role":"article"},"doc://FactoryKit/documentation/FactoryKit/Optionals":{"kind":"article","title":"Optionals and Dynamic Registration","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Optionals","url":"\/documentation\/factorykit\/optionals","type":"topic","abstract":[{"type":"text","text":"With Factory registrations can be performed at any time."}],"role":"article"},"doc://FactoryKit/documentation/FactoryKit/Tags":{"kind":"article","title":"Tags","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Tags","url":"\/documentation\/factorykit\/tags","type":"topic","abstract":[{"type":"text","text":"Obtaining a list of dependencies of a given type."}],"role":"article"},"doc://FactoryKit/documentation/FactoryKit/Cycle":{"kind":"article","title":"Resolution Cycles","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Cycle","url":"\/documentation\/factorykit\/cycle","type":"topic","abstract":[{"type":"text","text":"What’s a resolution cycle, and why should we care?"}],"role":"article"},"doc://FactoryKit/documentation/FactoryKit/Design":{"url":"\/documentation\/factorykit\/design","role":"article","title":"Designing Factory","abstract":[{"text":"Rationale behind the design decisions made in Factory 1.0 and 2.0","type":"text"}],"kind":"article","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Design","type":"topic"},"doc://FactoryKit/documentation/FactoryKit/Modules":{"kind":"article","title":"Modular Development","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Modules","url":"\/documentation\/factorykit\/modules","type":"topic","abstract":[{"type":"text","text":"Using Factory in a project with multiple modules."}],"role":"article"},"doc://FactoryKit/documentation/FactoryKit":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"A modern approach to Container-Based Dependency Injection for Swift and SwiftUI."}],"url":"\/documentation\/factorykit","role":"collection","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit","title":"FactoryKit"},"https://betterprogramming.pub/factory-and-functional-dependency-injection-2d0a38042d05":{"titleInlineContent":[{"type":"text","text":"Factory and Functional Dependency Injection"}],"url":"https:\/\/betterprogramming.pub\/factory-and-functional-dependency-injection-2d0a38042d05","type":"link","identifier":"https:\/\/betterprogramming.pub\/factory-and-functional-dependency-injection-2d0a38042d05","title":"Factory and Functional Dependency Injection"}}}