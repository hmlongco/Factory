{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Shared Class Container","level":3,"anchor":"Shared-Class-Container"},{"inlineContent":[{"text":"Here we instantiate our dependency from a shared class container.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class ContentViewModel: ObservableObject {","    let service = Container.shared.constructedService()","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This is the classic Service Locator pattern updated for Factory 2.0."}],"type":"paragraph"},{"type":"heading","text":"Initialization from Passed Container","level":3,"anchor":"Initialization-from-Passed-Container"},{"inlineContent":[{"text":"Passing an instance of a container to our view model and initializing service from that container.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class ContentViewModel: ObservableObject {","","    let service2: MyServiceType","","    init(container: Container) {","        service2 = container.service()","    }","    ","}"],"type":"codeListing"},{"type":"heading","text":"Lazy Initialization from Passed Container","level":3,"anchor":"Lazy-Initialization-from-Passed-Container"},{"inlineContent":[{"text":"Passing an instance of a container to our view model and saving it for later lazy initializers.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class ContentViewModel: ObservableObject {","","    private let container: Container","","    private lazy var service3: MyConstructedService = container.constructedService()","    private lazy var service4: MyServiceType = container.cachedService()","    private lazy var service5: SimpleService = container.singletonService()","    private lazy var service6: MyServiceType = container.sharedService()","","    init(container: Container) {","        self.container = container","    }","","}"],"type":"codeListing"},{"type":"heading","text":"Injected Property Wrappers","level":3,"anchor":"Injected-Property-Wrappers"},{"inlineContent":[{"type":"text","text":"Using the "},{"code":"@Injected","type":"codeVoice"},{"type":"text","text":" and "},{"code":"@LazyInjected","type":"codeVoice"},{"type":"text","text":" property wrappers to obtain dependencies using an Annotation pattern similar to that used by "},{"code":"EnvironmentObject","type":"codeVoice"},{"type":"text","text":" in SwiftUI."}],"type":"paragraph"},{"syntax":"swift","code":["class ContentViewModel: ObservableObject {","","    \/\/ Injected property from default container","    @Injected(\\.constructedService) var constructed","","    \/\/ Injected property from custom container","    @Injected(\\MyContainer.anotherService) var anotherService","","    \/\/ LazyInjected property from custom container","    @LazyInjected(\\MyContainer.myLazyService) var myLazyService","","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"One can also inject the view model itself."}],"type":"paragraph"},{"syntax":"swift","code":["struct ContentView: View {","    @InjectedObject(\\.contentViewModel) var model: ContentViewModel","    var body: some View {","        ...","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Injected","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/LazyInjected","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/WeakLazyInjected","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/DynamicInjected","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/InjectedObject","isActive":true},{"type":"text","text":" for more."}],"type":"paragraph"},{"type":"heading","level":3,"