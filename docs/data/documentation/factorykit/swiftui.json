{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/SwiftUI"},"sections":[],"metadata":{"modules":[{"name":"FactoryKit"}],"role":"article","title":"SwiftUI","roleHeading":"Article"},"kind":"article","variants":[{"paths":["\/documentation\/factorykit\/swiftui"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"title":"Development and Testing","identifiers":["doc:\/\/FactoryKit\/documentation\/FactoryKit\/Previews","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Testing","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Contexts","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Debugging","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Chains"],"generated":true,"anchor":"Development-and-Testing"}],"hierarchy":{"paths":[["doc:\/\/FactoryKit\/documentation\/FactoryKit"]]},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"text":"Factory can make SwiftUI easier to use when we’re using view models or services and those entities depend on internal dependencies. Let’s take a look.","type":"text"}],"type":"paragraph"},{"anchor":"StateObjects","type":"heading","level":2,"text":"StateObjects"},{"inlineContent":[{"text":"Factory can be used to assign a fully constructed dependency to a ","type":"text"},{"type":"codeVoice","code":"StateObject"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"ObservedObject"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ the view model","class ContentViewModel: ObservableObject {","    @Injected(\\.myService) private var service","    @Published var results: Results","    func load() async {","        results = await service.load()","    }","}","","\/\/ the factory","extension Container {","    var contentViewModel: Factory<ContentViewModel> {","        self { ContentViewModel() }","    }","}","","\/\/ the view","struct ContentView: View {","    @StateObject var viewModel = Container.shared.contentViewModel()","    var body: some View {","        ...","    }","}"]},{"inlineContent":[{"text":"Keep in mind that if you assign to an ","type":"text"},{"type":"codeVoice","code":"ObservedObject"},{"text":" your Factory is responsible for managing the object’s lifecycle (see the section on Scopes).","type":"text"}],"type":"paragraph"},{"anchor":"InjectedObject","type":"heading","level":2,"text":"InjectedObject"},{"inlineContent":[{"text":"Then again, if your view model is coming from Factory, we can bypass the shared container code and just use the ","type":"text"},{"type":"codeVoice","code":"InjectedObject"},{"text":" property wrapper.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ the view","struct ContentView: View {","    @InjectedObject(\\.contentViewModel) private var viewModel","    var body: some View {","        ...","    }","}"]},{"inlineContent":[{"text":"InjectedObject uses ","type":"text"},{"type":"codeVoice","code":"StateObject"},{"text":" under the hood, so ownership is implied.","type":"text"}],"type":"paragraph"},{"anchor":"ViewModel-Dependencies","type":"heading","level":2,"text":"ViewModel Dependencies"},{"inlineContent":[{"text":"Note that our view model used the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Injected","type":"reference"},{"text":" property wrapper to obtain its dependency.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class ContentViewModel: ObservableObject {","    @Injected(\\.myService) private var service","    ...","}"]},{"inlineContent":[{"text":"As such, there’s no particular reason to obtain the view model from Factory since the view model knows what it needs and it’s perfectly capable of managing things for itself.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct ContentView: View {","    @StateObject private var viewModel = ContentViewModel()","    var body: some View {","        ...","    }","}"]},{"inlineContent":[{"text":"That would be different if, for example, our view model wanted its dependencies passed via an initializer.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class ContentViewModel: ObservableObject {","    private let service: MyServiceType","    init(service: MyServiceType)","        self.service = service","    }","    ...","}"]},{"inlineContent":[{"text":"In which case we might indeed want our container to provide a fully initialized object.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["extension Container {","    var contentViewModel: Factory<ContentViewModel> {","        self { ContentViewModel(service: myService()) }","    }","    var myService: Factory<MyServiceType> {","        self { MyService() }","    }","}"]},{"inlineContent":[{"text":"And back to ","type":"text"},{"type":"codeVoice","code":"InjectedObject"},{"text":" we go.","type":"text"}],"type":"paragraph"},{"anchor":"Observation","type":"heading","level":2,"text":"Observation"},{"inlineContent":[{"text":"Apple added support for a new framework to iOS 17–Observation. Observation promises better efficiency and fewer view updates when used across multiple views. So how do we use it?","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Here’s our previous example, updated for Observation.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Observable","class ContentViewModel {","    @ObservationIgnored @Injected(\\.myService) private var service","    var results: Results","    func load() async {","        results = await service.load()","    }","}"]},{"inlineContent":[{"text":"We replaced the ","type":"text"},{"type":"codeVoice","code":"ObservableObject"},{"text":" protocol conformance with the ","type":"text"},{"type":"codeVoice","code":"@Observable"},{"text":" macro and removed the ","type":"text"},{"type":"codeVoice","code":"@Published"},{"text":" attribute from results.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note, however, that we needed to add ","type":"text"},{"type":"codeVoice","code":"@ObservationIgnored"},{"text":" to our ","type":"text"},{"type":"codeVoice","code":"Injected"},{"text":" service property wrapper. It’s a private value and doesn’t need to be visible outside of our view model.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Here’s the view.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct ContentView: View {","    @InjectedObservable(\\.contentViewModel) var viewModel","    var body: some View {","        ...","    }","}"]},{"inlineContent":[{"text":"Instead of ","type":"text"},{"type":"codeVoice","code":"InjectedObject"},{"text":" we use ","type":"text"},{"type":"codeVoice","code":"InjectedObservable"},{"text":", a new property wrapper that understands how to work with the Observable protocol established by Observation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"InjectedObservable uses "},{"code":"State","type":"codeVoice"},{"type":"text","text":" under the hood and, like "},{"code":"InjectedObject","type":"codeVoice"},{"type":"text","text":", owns the instance in question."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"One should also note that InjectedObject “thunks” its parameter and only one instance of the injected view model will be created for the lifetime of the view.","type":"text"}],"type":"emphasis"}],"type":"paragraph"},{"anchor":"Coping-With-MainActor","text":"Coping With @MainActor","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"One last thing missing from our SwiftUI sample code is @MainActor, that Swift Concurrency attribute used to ensure all view updates occur on the main thread."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Let’s update our view model and see what else needs to change."}],"type":"paragraph"},{"code":["\/\/ the view model","@MainActor","@Observable","class ContentViewModel {","    @ObservationIgnored @Injected(\\.myService) private var service","    var results: Results","    func load() async {","        results = await service.load()","    }","}","","\/\/ the factory","extension Container {","    @MainActor","    var contentViewModel: Factory<ContentViewModel> {","        self { ContentViewModel() }","    }","}","","\/\/ the view","struct ContentView: View {","    @InjectedObservable(\\.contentViewModel) var viewModel","    var body: some View {","        ...","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"As you can see adding "},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":" to our view model also required us to annotate the Factory accordingly, adding it to both the definition "},{"inlineContent":[{"text":"and","type":"text"}],"type":"emphasis"},{"type":"text","text":" to the factory closure."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"While we’d never do it in this case, adding actor isolation to the base factory also means that we’d need to do so again should we ever want to register a new factory."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Container.shared.contentViewModel.register { ","    ContentViewModel()","}",""]},{"text":"Resolving Actor-Isolated Factory’s","anchor":"Resolving-Actor-Isolated-Factorys","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Here’s the catch that the compiler won’t warn you about. When you annotate the Factory property with "},{"type":"codeVoice","code":"@MainActor"},{"type":"text","text":", the registration closure inherits that isolation. But Factory’s resolution path is synchronous and "},{"type":"codeVoice","code":"nonisolated"},{"type":"text","text":". The Factory is returned on the actor, but "},{"type":"codeVoice","code":"callAsFunction()"},{"text":" runs the closure on whatever executor the ","type":"text"},{"inlineContent":[{"type":"text","text":"caller"}],"type":"emphasis"},{"text":" happens to be on, and if that isn’t the main actor Swift’s dynamic isolation check on the closure traps.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Task.detached {","    \/\/ The property getter is @MainActor, so this access needs await.","    let factory = await Container.shared.contentViewModel","    \/\/ callAsFunction() is nonisolated, so no await here. It runs the","    \/\/ @MainActor closure on this background executor and crashes:","    \/\/ EXC_BREAKPOINT, dispatch_assert_queue_fail, _swift_task_checkIsolatedSwift.","    let viewModel = factory()","}"]},{"inlineContent":[{"type":"text","text":"Notice that adding "},{"code":"await","type":"codeVoice"},{"type":"text","text":" to the property access does "},{"inlineContent":[{"text":"not","type":"text"}],"type":"emphasis"},{"text":" save you. The ","type":"text"},{"type":"codeVoice","code":"await"},{"text":" belongs to the property getter, not to ","type":"text"},{"type":"codeVoice","code":"callAsFunction()"},{"type":"text","text":". The getter builds the lightweight "},{"code":"Factory","type":"codeVoice"},{"type":"text","text":" struct on the main actor and hands it back; the actual resolution still happens wherever the caller is running. Synchronous resolution has no suspension point at which Swift can hop actors, so there’s nowhere for it to cross back to the main actor."}],"type":"paragraph"},{"inlineContent":[{"text":"This isn’t unique to ","type":"text"},{"type":"codeVoice","code":"@MainActor"},{"type":"text","text":". "},{"inlineContent":[{"type":"text","text":"Any"}],"type":"emphasis"},{"type":"text","text":" actor-isolated factory, including one bound to a custom global actor, will trap the same way when it’s resolved from a mismatched executor."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The fix is simpl and lives on the calling side: resolve the factory from the isolation its closure requires. For a "},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":" factory, hop onto the main actor first and resolve there."}],"type":"paragraph"},{"code":["Task.detached {","    let viewModel = await MainActor.run {","        Container.shared.contentViewModel()","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"code":"MainActor.run","type":"codeVoice"},{"type":"text","text":" runs both the property access "},{"inlineContent":[{"text":"and","type":"text"}],"type":"emphasis"},{"type":"text","text":" "},{"code":"callAsFunction()","type":"codeVoice"},{"text":" on the main actor, so the closure’s isolation check passes. The resolved instance then crosses back to the caller as a normal ","type":"text"},{"type":"codeVoice","code":"Sendable"},{"text":" value.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In practice you rarely hit this, because most resolution of a "},{"code":"@MainActor","type":"codeVoice"},{"text":" dependency already happens from main-actor-isolated code. The ","type":"text"},{"type":"codeVoice","code":"@Injected"},{"text":" property wrapper inside a ","type":"text"},{"type":"codeVoice","code":"@MainActor"},{"text":" view model, for example, resolves on the main actor by construction. The crash shows up when you reach for a ","type":"text"},{"type":"codeVoice","code":"@MainActor"},{"text":" factory from a background ","type":"text"},{"type":"codeVoice","code":"Task"},{"text":", a ","type":"text"},{"type":"codeVoice","code":"Task.detached"},{"text":", or a ","type":"text"},{"type":"codeVoice","code":"nonisolated"},{"text":" function.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Defining and using dependencies in SwiftUI."}],"references":{"doc://FactoryKit/documentation/FactoryKit/Previews":{"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Previews","kind":"article","title":"SwiftUI Previews","role":"article","url":"\/documentation\/factorykit\/previews","abstract":[{"type":"text","text":"Mocking dependencies for SwiftUI Previews."}],"type":"topic"},"doc://FactoryKit/documentation/FactoryKit/Chains":{"type":"topic","abstract":[{"type":"text","text":"Detecting and solving Circular Dependency Chains."}],"title":"Circular Dependency Chains","url":"\/documentation\/factorykit\/chains","role":"article","kind":"article","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Chains"},"doc://FactoryKit/documentation/FactoryKit/Testing":{"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Testing","kind":"article","title":"Testing","role":"article","url":"\/documentation\/factorykit\/testing","abstract":[{"type":"text","text":"Using Factory for Unit and UI Testing."}],"type":"topic"},"doc://FactoryKit/documentation/FactoryKit/Debugging":{"url":"\/documentation\/factorykit\/debugging","abstract":[{"type":"text","text":"Additional support for debugging resolution cycles, dependency chains and other issue."}],"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Debugging","role":"article","type":"topic","kind":"article","title":"Debugging"},"doc://FactoryKit/documentation/FactoryKit/Injected":{"navigatorTitle":[{"text":"Injected","kind":"identifier"}],"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Injected","role":"symbol","type":"topic","abstract":[{"text":"Convenience property wrapper takes a factory and resolves an instance of the desired type.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Injected","kind":"identifier"}],"url":"\/documentation\/factorykit\/injected","kind":"symbol","title":"Injected"},"doc://FactoryKit/documentation/FactoryKit":{"abstract":[{"type":"text","text":"A modern approach to Container-Based Dependency Injection for Swift and SwiftUI."}],"kind":"symbol","type":"topic","role":"collection","title":"FactoryKit","url":"\/documentation\/factorykit","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit"},"doc://FactoryKit/documentation/FactoryKit/Contexts":{"abstract":[{"text":"Changing injection results under special circumstances.","type":"text"}],"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Contexts","title":"Contexts","type":"topic","role":"article","url":"\/documentation\/factorykit\/contexts","kind":"article"}}}