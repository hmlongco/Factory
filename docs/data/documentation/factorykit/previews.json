{"metadata":{"roleHeading":"Article","role":"article","title":"SwiftUI Previews","modules":[{"name":"FactoryKit"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/factorykit\/previews"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Factory can make SwiftUI Previews easier when we’re using View Models and those view models depend on internal dependencies. Let’s take a look.","type":"text"}]},{"type":"heading","text":"SwiftUI Previews","anchor":"SwiftUI-Previews","level":2},{"type":"paragraph","inlineContent":[{"text":"Here’s an example of updating a view model’s service dependency in order to setup a particular state for  preview.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ the view model","class ContentViewModel: ObservableObject {","    @Injected(\\.myService) private var service","    ...","    func load() async {","        let results = await service.load()","        ...","    }","}","","\/\/ the view","struct ContentView: View {","    @StateObject var viewModel = ContentViewModel()","    var body: some View {","        ...","    }","}","","\/\/ the preview","struct ContentView_Previews: PreviewProvider {","    static var previews: some View {","        let _ = Container.shared.myService.register { MockServiceN(4) }","        ContentView()","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"If we can control where and how the view model gets its data then we can put the view model into pretty much any state we choose.","type":"text"}]},{"type":"heading","text":"SwiftUI #Previews","anchor":"SwiftUI-Previews","level":2},{"type":"paragraph","inlineContent":[{"text":"The same can be done using the new macro-based #Preview option added to Xcode 15.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["#Preview {","    let _ = Container.shared.myService.register { MockServiceN(4) }","    ContentView()","}"]},{"type":"paragraph","inlineContent":[{"text":"In fact, this ","type":"text"},{"type":"codeVoice","code":"let _ = Container.shared.xxx.register"},{"text":" syntax happens so frequently that Factory 2.5 added some sugar to make it a bit easier.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["#Preview {","    Container.shared.myService.preview { MockServiceN(4) }","    ContentView()","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"preview"},{"text":" modifier wraps ","type":"text"},{"type":"codeVoice","code":"register"},{"text":" and also returns an EmptyView, satisfying SwiftUI’s ViewBuilder and eliminating the need for ","type":"text"},{"type":"codeVoice","code":"let _ ="},{"text":".","type":"text"}]},{"type":"heading","text":"Multiple Registrations","anchor":"Multiple-Registrations","level":2},{"type":"paragraph","inlineContent":[{"text":"There’s also a variant for Containers if you need to do multiple registrations.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["#Preview {","    Container.preview {","        $0.myService.register { MockServiceN(4) }","        $0.anotherService.register { MockAnotherService() }","    }","    ContentView()","}"]},{"type":"heading","text":"Multiple Previews","anchor":"Multiple-Previews","level":2},{"type":"paragraph","inlineContent":[{"text":"If we want to do multiple previews at once, each with different data, we simply need to instantiate our view models and pass them into the view as parameters.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Prior to Xcode 15 and given the ContentView we used above, we’d need to do:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct ContentView_Previews: PreviewProvider {","    static var previews: some View {","        Group {","            let _ = Container.shared.myService.register { MockServiceN(4) }","            let vm1 = ContentViewModel()","            ContentView(viewModel: vm1)","            ","            let _ = Container.shared.myService.register { MockServiceN(8) }","            let vm2 = ContentViewModel()","            ContentView(viewModel: vm2)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Of course, it’s even easier with #Preview as each one runs in its own context..","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["#Preview {","    Container.shared.myService.preview { MockServiceN(4) }","    ContentView()","}","#Preview {","    Container.shared.myService.preview { MockServiceN(0) }","    ContentView()","}"]},{"type":"paragraph","inlineContent":[{"text":"Since the #Preview macro has been back-ported to iOS 13, there’s really no need to use the old syntax.","type":"text"}]},{"type":"heading","text":"Common Setup","anchor":"Common-Setup","level":2},{"type":"paragraph","inlineContent":[{"text":"If we have several mocks that we use all of the time in our previews or unit tests, we can also add a setup function to a given container to make this easier.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["extension Container {","    func setupMocks() {","        myService.register { MockServiceN(4) }","        sharedService.register { MockService2() }","    }","}","","#Preview {","    let _ = Container.shared.setupMocks()","    ContentView()","}"]},{"type":"paragraph","inlineContent":[{"text":"Or if you want to roll with the cool kids and continue with the preview syntax…","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["extension Container {","    func setupMocks() -> EmptyView {","        myService.register { MockServiceN(4) }","        sharedService.register { MockService2() }","        return EmptyView()","    }","}","","#Preview {","    Container.shared.setupMocks()","    ContentView()","}"]}]}],"kind":"article","seeAlsoSections":[{"title":"Development and Testing","identifiers":["doc:\/\/FactoryKit\/documentation\/FactoryKit\/SwiftUI","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Testing","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Contexts","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Debugging","doc:\/\/FactoryKit\/documentation\/FactoryKit\/Chains"],"generated":true,"anchor":"Development-and-Testing"}],"abstract":[{"type":"text","text":"Mocking dependencies for SwiftUI Previews."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Previews","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/FactoryKit\/documentation\/FactoryKit"]]},"references":{"doc://FactoryKit/documentation/FactoryKit/Debugging":{"abstract":[{"text":"Additional support for debugging resolution cycles, dependency chains and other issue.","type":"text"}],"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Debugging","type":"topic","kind":"article","role":"article","url":"\/documentation\/factorykit\/debugging","title":"Debugging"},"doc://FactoryKit/documentation/FactoryKit/Contexts":{"abstract":[{"text":"Changing injection results under special circumstances.","type":"text"}],"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Contexts","type":"topic","kind":"article","role":"article","url":"\/documentation\/factorykit\/contexts","title":"Contexts"},"doc://FactoryKit/documentation/FactoryKit/Chains":{"abstract":[{"text":"Detecting and solving Circular Dependency Chains.","type":"text"}],"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Chains","type":"topic","kind":"article","role":"article","url":"\/documentation\/factorykit\/chains","title":"Circular Dependency Chains"},"doc://FactoryKit/documentation/FactoryKit/SwiftUI":{"abstract":[{"text":"Defining and using dependencies in SwiftUI.","type":"text"}],"type":"topic","url":"\/documentation\/factorykit\/swiftui","title":"SwiftUI","kind":"article","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/SwiftUI","role":"article"},"doc://FactoryKit/documentation/FactoryKit/Testing":{"abstract":[{"text":"Using Factory for Unit and UI Testing.","type":"text"}],"identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit\/Testing","type":"topic","kind":"article","role":"article","url":"\/documentation\/factorykit\/testing","title":"Testing"},"doc://FactoryKit/documentation/FactoryKit":{"title":"FactoryKit","role":"collection","kind":"symbol","identifier":"doc:\/\/FactoryKit\/documentation\/FactoryKit","type":"topic","url":"\/documentation\/factorykit","abstract":[{"text":"A modern approach to Container-Based Dependency Injection for Swift and SwiftUI.","type":"text"}]}}}